rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global safety net - Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    // Validation Blueprints
    function isValidUser(data) {
      return data.keys().hasAll(['name', 'employeeId', 'sector', 'createdAt', 'level']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.employeeId is string && data.employeeId.size() > 0 && data.employeeId.size() <= 50 &&
             data.sector is string && data.sector.size() > 0 && data.sector.size() <= 100 &&
             data.level in ['bronze', 'prata', 'ouro'] &&
             (data.get('preferredDayOff', null) == null || data.preferredDayOff is string) &&
             (data.get('preferredSundaysOff', null) == null || data.preferredSundaysOff is list) &&
             data.keys().size() >= 5;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidCheckin(data) {
      return data.keys().hasAll(['userId', 'userName', 'date', 'timestamp', 'responses']) &&
             data.userId is string && data.userId.size() <= 50 &&
             data.userName is string && data.userName.size() <= 100 &&
             data.date is string && data.date.size() == 10 &&
             data.responses is map &&
             (data.averageScore == null || data.averageScore is number) &&
             data.keys().size() >= 5;
    }

    function isValidReport(data) {
      return data.keys().hasAll(['protocol', 'category', 'description', 'status', 'createdAt', 'updatedAt']) &&
             data.protocol is string && data.protocol.size() > 0 && data.protocol.size() <= 100 &&
             data.category is string &&
             data.description is string && data.description.size() <= 5000 &&
             data.status in ['recebida', 'em_análise', 'resolvida'];
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['text', 'senderId', 'senderName', 'timestamp']) &&
             data.text is string && data.text.size() <= 2000 &&
             data.senderId is string && data.senderId.size() <= 50 &&
             data.senderName is string && data.senderName.size() <= 100;
    }

    match /users/{userId} {
      allow get: if true;
      allow list: if isSignedIn();
      allow create: if isValidUser(incoming());
      allow update: if (isOwner(userId) || isSignedIn()) && isValidUser(incoming());
      allow delete: if false; 
    }

    match /checkins/{checkinId} {
      allow create: if isValidCheckin(incoming());
      allow update: if isValidCheckin(incoming());
      allow list, get: if true; // Open for this demo (Dashboard needs to see all)
    }

    match /messages/{messageId} {
      allow list: if true;
      allow get: if true;
      allow create: if isValidMessage(incoming());
      allow update, delete: if false;
    }
    
    match /sectors/{sectorId} {
      allow read: if true;
      allow write: if false;
    }
    
    match /system/{docId} {
      allow read: if true;
    }

    match /reports/{reportId} {
      allow create: if isValidReport(incoming()) && incoming().status == 'recebida';
      allow list, get: if true; // Dashboard needs to see all
      allow update: if isValidReport(incoming());
      allow delete: if false;
    }
  }
}
