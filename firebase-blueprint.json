{
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Employee profile"
    },
    "/checkins/{checkinId}": {
      "schema": "Checkin",
      "description": "Daily survey responses"
    },
    "/sectors/{sectorId}": {
      "schema": "Sector",
      "description": "List of company departments"
    },
    "/messages/{messageId}": {
      "schema": "Message",
      "description": "Chat messages between supervisors"
    },
    "/reports/{reportId}": {
      "schema": "Report",
      "description": "Anonymous reports of inappropriate conduct"
    }
  },
  "entities": {
    "Report": {
      "title": "Anonymous Report",
      "description": "Anonymous report of workplace misconduct",
      "type": "object",
      "properties": {
        "protocol": { "type": "string" },
        "category": { "type": "string", "enum": ["assédio_moral", "assédio_sexual", "abuso_autoridade", "outros"] },
        "description": { "type": "string" },
        "evidenceUrl": { "type": "string" },
        "status": { "type": "string", "enum": ["recebida", "em_análise", "resolvida"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["protocol", "category", "description", "status", "createdAt", "updatedAt"]
    },
    "User": {
      "title": "User",
      "description": "Information about the employee",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "employeeId": { "type": "string" },
        "sector": { "type": "string" },
        "isAdmin": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "level": { "type": "string", "enum": ["bronze", "prata", "ouro"] },
        "preferredDayOff": { "type": "string" },
        "preferredSundaysOff": { 
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "required": ["name", "employeeId", "sector", "level"]
    },
    "Checkin": {
      "title": "Daily Check-in",
      "description": "Daily feedback from an employee",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "sector": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "timestamp": { "type": "string", "format": "date-time" },
        "responses": {
          "type": "object",
          "description": "Map of questionId to score (1-4)"
        },
        "totalScore": { "type": "number" },
        "averageScore": { "type": "number" },
        "comments": { "type": "string" },
        "anonymous": { "type": "boolean" },
        "checkInTime": { "type": "string", "format": "date-time" },
        "lunchStartTime": { "type": "string", "format": "date-time" },
        "lunchEndTime": { "type": "string", "format": "date-time" },
        "checkOutTime": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "date"]
    },
    "Sector": {
      "title": "Sector",
      "description": "Department or team",
      "type": "object",
      "properties": {
        "name": { "type": "string" }
      },
      "required": ["name"]
    },
    "Message": {
      "title": "Message",
      "description": "Real-time message in the leadership chat",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "senderSector": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["text", "senderId", "senderName", "timestamp"]
    }
  }
}
